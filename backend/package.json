{
  "name": "sept-innovation-backend",
  "version": "1.0.0",
  "description": "Secure AI-powered analytics platform with local LLM processing",
  "main": "dist/src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "audit-logs": "node dist/scripts/auditLogViewer.js",
    "db:setup": "psql -U postgres -d analytics_db -f database/schema.sql",
    "db:seed": "psql -U postgres -d analytics_db -f database/sample_data.sql",
    "db:reset": "psql -U postgres -c 'DROP DATABASE IF EXISTS analytics_db; CREATE DATABASE analytics_db;'"
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.1",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^12.2.1",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mssql": "^8.1.0",
    "@types/node": "^20.10.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
